# --- Supabase (existing) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- CRM session (required in production) ---
# Min 32 characters. Rotating logs everyone out.
CRM_SESSION_SECRET=

# Local dev only: allows a fixed dev secret (never use in production)
# AUTH_INSECURE_DEV=true

# --- Bootstrap admins (first deploy) ---
# Comma-separated usernames; rows are created on first login bootstrap if missing.
CRM_ADMIN_USERNAMES=admin
# Shared initial password for those new admin rows only (change after first login)
CRM_ADMIN_INITIAL_PASSWORD=

# Optional display name for the default company row
CRM_COMPANY_NAME=Default Company

# Optional: allow "Send as tenant" tester UI on production (default off; dev enables without this)
# CRM_SIMULATE_INBOUND_ENABLED=true

# --- Dev login without Supabase (optional) ---
# If Supabase is unset, you can still get an admin session for UI work:
# CRM_DEV_USERNAME=dev
# CRM_DEV_PASSWORD=your-dev-password
